<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}TV FR{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📺</text></svg>">
        {% block stylesheets %}
            {{ vite_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ vite_entry_script_tags('app') }}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script>
            // idiomorph DOM morphing ejects Lit's comment markers used by NordHealth components.
            // Force a full reload instead so Lit reinitialises cleanly.
            Idiomorph.morph = () => window.location.reload()
        </script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <nord-layout nav-open>
            <nord-navigation slot="nav">
                <nord-button slot="header" href="{{ path('home') }}" expand>
                    <nord-avatar slot="start" name="TV FR" variant="square">T</nord-avatar>
                    TV FR
                </nord-button>

                <nord-nav-group heading="Chaînes">
                    <nord-nav-item href="{{ path('home') }}" icon="interface-television">Chaîne TNT</nord-nav-item>
                    <nord-nav-item href="{{ path('favorites') }}" icon="interface-star">Favoris</nord-nav-item>
                    <nord-nav-item href="{{ path('channels_index') }}" icon="navigation-grid">Toutes les chaînes</nord-nav-item>
                </nord-nav-group>

                <nord-nav-group heading="Programmes">
                    <nord-nav-item href="{{ path('programs_now') }}" icon="interface-time">Maintenant</nord-nav-item>
                    <nord-nav-item href="{{ path('programs_tonight') }}" icon="interface-moon">Ce Soir</nord-nav-item>
                </nord-nav-group>
            </nord-navigation>

            <nord-top-bar slot="top-bar">
                <nord-input expand label="Recherche" hide-label type="search" placeholder="Rechercher une chaîne ou un programme…"></nord-input>

                <nord-dropdown slot="end" align="start" position="block-end">
                    <nord-button variant="plain" slot="toggle" aria-describedby="user-tooltip">
                        <nord-avatar style="transform: translateY(-1px)" name="Utilisateur">U</nord-avatar>
                    </nord-button>
                    <nord-avatar slot="header" size="s" name="Utilisateur">U</nord-avatar>
                    <p slot="header" class="n-color-text-weak n-font-size-s">
                        Connecté en tant que <span class="n-font-weight-active">Utilisateur</span>
                    </p>
                    <nord-dropdown-group>
                        <nord-dropdown-item>Mon profil</nord-dropdown-item>
                        <nord-dropdown-item>Paramètres</nord-dropdown-item>
                    </nord-dropdown-group>
                    <nord-dropdown-item>
                        Se déconnecter
                        <nord-icon slot="end" name="interface-logout"></nord-icon>
                    </nord-dropdown-item>
                </nord-dropdown>
                <nord-tooltip id="user-tooltip">Utilisateur</nord-tooltip>
            </nord-top-bar>

            <nord-header slot="header">
                <h1 class="n-typescale-l">
                    {% block page_title %}{% endblock %}
                </h1>
            </nord-header>

            <div class="tv__body">
                {% block body %}{% endblock %}
            </div>
        </nord-layout>

        <nord-command-menu></nord-command-menu>
    </body>
</html>
